{
    "version": "0.2.0",
    "configurations": [

        {
            "name": "HPKE Encrypt0",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/hpke_cli",
            "args": [
                "encrypt",
                "--mode", "encrypt0",
                "--recipient-key", "${workspaceFolder}/bob_pub.cbor",
                "--payload", "${workspaceFolder}/payload.txt",
                "--aad", "${workspaceFolder}/aad.bin",
                "--out", "${workspaceFolder}/msg_encrypt0.cbor"
            ],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ]
        }
    ]
}
